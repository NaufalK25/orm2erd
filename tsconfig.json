{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["src", "test"],
  // These fixtures use TypeORM decorators, which require
  // experimentalDecorators/emitDecoratorMetadata (deliberately not enabled
  // here — see each fixture's own tsconfig.json instead). They're compiled
  // separately by the TypeORM adapter itself (runTargetTsc, index.ts), not
  // by this project's own typecheck/build.
  "exclude": [
    "test/fixtures/typeorm/adapter/basic",
    "test/fixtures/typeorm/adapter/composite",
    "test/fixtures/typeorm/adapter/legacy-ormconfig"
  ]
}
