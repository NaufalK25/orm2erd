{
  "name": "orm2erd",
  "version": "1.5.0",
  "description": "Generate ERD diagrams (Mermaid, DBML, PlantUML, D2, and more) straight from your ORM's models/schema — no manual diagramming.",
  "bin": {
    "orm2erd": "./bin/orm2erd.js"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "erd",
    "entity-relationship-diagram",
    "orm",
    "prisma",
    "sequelize",
    "mongoose",
    "typeorm",
    "mermaid",
    "dbml",
    "plantuml",
    "d2",
    "nomnoml",
    "quickdbd",
    "dbdiagram",
    "schema",
    "database",
    "diagram",
    "cli"
  ],
  "author": "Muhammad Naufal Kateni <naufalkateni2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaufalK25/orm2erd.git"
  },
  "bugs": {
    "url": "https://github.com/NaufalK25/orm2erd/issues"
  },
  "homepage": "https://github.com/NaufalK25/orm2erd#readme",
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@prisma/internals": "^7.8.0",
    "c12": "^3.3.4",
    "commander": "^15.0.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "mongoose": "^9.7.4",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.14.1",
    "tsup": "^8.5.1",
    "typeorm": "^1.1.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
